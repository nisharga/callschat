{
  "expo": {
    "name": "CallsChat",
    "slug": "callschat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./app/src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.callschat.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.callschat.app"
    },
    "web": {
      "favicon": "./app/src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "62fe4d4c-5a41-4a9c-a15e-8fed4aa7e450"
      }
    }
  }
}
